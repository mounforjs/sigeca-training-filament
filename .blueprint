    - database/migrations/2026_04_01_211629_create_scenes_table.php
    - database/migrations/2026_04_01_211630_create_interactions_table.php
    - database/migrations/2026_04_01_211631_create_constructions_table.php
    - database/migrations/2026_04_01_211632_create_meanings_table.php
    - database/migrations/2026_04_01_211633_create_capacitacions_table.php
    - database/migrations/2026_04_01_211634_create_estados_table.php
    - database/migrations/2026_04_01_211635_create_municipios_table.php
