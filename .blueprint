    - database/migrations/2026_04_01_164254_create_scenes_table.php
    - database/migrations/2026_04_01_164255_create_interactions_table.php
    - database/migrations/2026_04_01_164256_create_constructions_table.php
    - database/migrations/2026_04_01_164257_create_meanings_table.php
    - database/migrations/2026_04_01_164258_create_capacitacions_table.php
    - database/migrations/2026_04_01_164259_create_estados_table.php
