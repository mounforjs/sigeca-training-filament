    - app/Models/Interaction.php
    - app/Models/Construction.php
    - app/Models/Meaning.php
    - app/Models/Capacitacion.php
    - app/Models/Estado.php
    - app/Models/Municipio.php
    - app/Models/Parroquia.php
    - app/Models/Asistencia.php
    - app/Models/User.php
models:
    User: { relationships: { belongsToMany: Capacitacion } }
    Scene: { name: string, meaning: string, description: string, usage: string, nanobanana: string, grok: string, construction_id: unsignedInteger, interaction_id: unsignedInteger, relationships: { belongsTo: 'Construction, Interaction' } }
    Interaction: { title: string, type: string, relationships: { hasMany: Scene } }
    Construction: { title: string, type: string, relationships: { hasMany: 'Meaning, Scene' } }
    Meaning: { title: string, description: longtext, construction_id: unsignedInteger, relationships: { belongsTo: Construction } }
    Capacitacion: { titulo: string, descripcion: longtext, fecha: date, estado_id: unsignedInteger, municipio_id: unsignedInteger, parroquia_id: unsignedInteger, status: string, relationships: { belongsToMany: User, belongsTo: 'Estado, Municipio' } }
    Estado: { nombre_estado: string, abr: 'string nullable' }
    Municipio: { nombre_municipio: string, estado_id: unsignedInteger, municipio_id: unsignedInteger, relationships: { belongsTo: Estado } }
    Parroquia: { nombre_parroquia: string, estado_id: unsignedInteger, municipio_id: unsignedInteger, parroquia_id: unsignedInteger, relationships: { belongsTo: 'Estado, Municipio' } }
    Asistencia: { fecha: date, asistio: boolean, alumno_id: unsignedInteger, capacitacion_id: unsignedInteger, relationships: { belongsTo: Capacitacion } }
