created:
    - database/factories/SceneFactory.php
    - database/factories/InteractionFactory.php
    - database/factories/ConstructionFactory.php
    - database/factories/MeaningFactory.php
    - database/factories/CapacitacionFactory.php
    - database/factories/EstadoFactory.php
    - database/factories/MunicipioFactory.php
    - database/factories/ParroquiaFactory.php
    - database/factories/AsistenciaFactory.php
